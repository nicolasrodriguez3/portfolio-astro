---
import PageLayout from '@/layouts/PageLayout.astro'
import Hero from '@/components/shared/Hero.astro'
import CTA from '@/components/shared/CTA.astro'
import AboutSection from '@/components/portfolio/AboutSection.astro'
import StackSection from '@/components/portfolio/StackSection.astro'
import ExperienceSection from '@/components/portfolio/ExperienceSection.astro'
import ProjectsSection from '@/components/portfolio/ProjectsSection.astro'
import { profile } from '@/data/profile'
import { technologies } from '@/data/technologies'
import { experiences } from '@/data/experience'
import { projects } from '@/data/projects'

const title = 'Nicolás Rodríguez | Full Stack Developer'
const description =
  'Full Stack Developer con experiencia en React, PHP, Python y desarrollo de sistemas ERP. Apasionado por la arquitectura de software y el backend.'
const canonical = 'https://www.nicorodriguez.com.ar/hire-me'

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: profile.name,
  jobTitle: profile.recruiter.subtitle,
  url: canonical,
  email: profile.email,
  sameAs: [profile.social.linkedin, profile.social.github].filter(Boolean),
}
---

<PageLayout
  mode="recruiter"
  title={title}
  description={description}
  canonical={canonical}
  ogImage="/og-recruiter.jpg"
  ogType="profile"
  {jsonLd}
>
  <!-- Hero -->
  <Hero
    headline={profile.recruiter.headline}
    subtitle={profile.recruiter.subtitle}
    subtitleSize="sm"
    align="left"
    gradient={true}
    buttons={[
      {
        label: 'Descargar CV',
        href: profile.cvUrl,
        variant: 'primary',
        download: true,
      },
      {
        label: 'LinkedIn',
        href: profile.social.linkedin,
        variant: 'secondary',
        external: true,
      },
      {
        label: 'GitHub',
        href: profile.social.github,
        variant: 'ghost',
        external: true,
      },
    ]}
  />

  <!-- Value Prop -->
  <section class="section-padding bg-hex-section">
    <div class="container-default text-center">
      <p class="text-xl md:text-2xl text-zinc-300 max-w-4xl mx-auto leading-relaxed">
        {profile.recruiter.valueProp}
      </p>
    </div>
  </section>

  <!-- About -->
  <AboutSection profile={profile} />

  <!-- Stack -->
  <StackSection {technologies} />

  <!-- Experience -->
  <ExperienceSection {experiences} />

  <!-- Projects -->
  <ProjectsSection {projects} />

  <!-- Final CTA -->
  <CTA
    headline="¿Buscás un desarrollador para tu equipo?"
    description="Si estás buscando un perfil proactivo con experiencia real en sistemas productivos y pasión por la buena arquitectura, hablemos."
    buttons={[
      {
        label: 'Descargar CV',
        href: profile.cvUrl,
        variant: 'primary',
        download: true,
      },
      {
        label: 'Contactarme',
        href: `mailto:${profile.email}`,
        variant: 'secondary',
      },
    ]}
  />
</PageLayout>
