---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Container from '@/components/ui/Container.astro'
---

<BaseLayout
  title="Página no encontrada — Nicolás Rodríguez"
  description="La página que buscas no existe. Volvé al inicio para explorar el sitio."
  canonical="https://www.nicorodriguez.com.ar/404"
>
  <main class="min-h-screen flex items-center justify-center section-padding">
    <Container size="narrow" class="text-center">
      <div class="space-y-6">
        <!-- 404 Hero -->
        <h1 class="text-8xl md:text-9xl font-bold heading-gradient leading-none">
          404
        </h1>

        <div class="space-y-2">
          <p class="text-xl md:text-2xl text-zinc-300 font-medium">
            La página que buscas no existe
          </p>
          <p class="text-zinc-500 max-w-md mx-auto">
            O fue movida, o nunca existió. Volvamos al inicio.
          </p>
        </div>

        <!-- Decorative accent line -->
        <div class="w-20 h-1 bg-gradient-to-r from-indigo-500 to-violet-600 rounded-full mx-auto"></div>

        <!-- Back button -->
        <a
          href="/"
          class="inline-flex items-center justify-center font-medium rounded-lg transition-all duration-200 focus:outline-none no-underline px-7 py-3.5 text-base bg-gradient-to-br from-indigo-500 to-violet-600 text-white border-none hover:brightness-110 hover:shadow-lg hover:shadow-indigo-500/20 active:scale-[0.98] focus-visible:ring-2 focus-visible:ring-indigo-400 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="mr-2"
          >
            <path d="M19 12H5" />
            <polyline points="12 19 5 12 12 5" />
          </svg>
          Volver al inicio
        </a>
      </div>
    </Container>
  </main>
</BaseLayout>
