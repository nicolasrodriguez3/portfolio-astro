---
interface Props {
  title?: string
  class?: string
  id?: string
}

const { title, class: className, id } = Astro.props
---

<section class:list={["py-20 px-3", className]} id={id}>
  <h2 class="section-title text-3xl font-bold tracking-tighter sm:text-4xl md:text-5xl">{title}</h2>
  <slot />
</section>

<script>
  import SplitType from "split-type"
  import { gsap } from "gsap"
  import { ScrollTrigger } from "gsap/ScrollTrigger"

  gsap.registerPlugin(ScrollTrigger)

  const text = new SplitType(".section-title", { types: "words,chars" })

  gsap.utils.toArray(".section-title").forEach((title: HTMLElement) => {
    const text = new SplitType(title, { types: "words,chars" })

    gsap.from(text.chars, {
      opacity: 0,
      x: 50,
      duration: 0.5,
      ease: "power2.out",
      stagger: 0.1,
      scrollTrigger: {
        trigger: title,
        start: "top 80%",
        toggleActions: "play none none reverse",
      },
    })
  })
  
</script>
