---
import Section from "./Section.astro"
import SocialButton from "./SocialButton.astro"
import EmailIcon from "./icons/EmailIcon.astro"
import GithubIcon from "./icons/GithubIcon.astro"
import LinkedinIcon from "./icons/LinkedinIcon.astro"

import { CONTACT } from "../constants/contact"
import { getHero } from "../lib/content"

const hero = await getHero()
---

<Section class="flex flex-col justify-center flex-wrap px-3 min-h-[75vh]">
  <picture class="fade-in mb-4">
    <img
      class="rounded-full bg-blue-300 size-20 object-cover"
      src={hero?.fotoPerfil || "/img-perfil.png"}
      alt="Foto de mi persona"
    />
  </picture>
  <div class="fade-in flex flex-col justify-center mb-8">
    <p class="text-3xl md:text-4xl mb-4">¡Hola! 👋🏻</p>
    <h1
      class="text-4xl md:text-5xl self-start font-semibold bg-gradient-to-br from-purple-600 to-blue-500 inline-block text-transparent bg-clip-text py-1">
      {hero?.titulo || "Soy Nicolás Rodríguez"}
    </h1>
    <h3 class="text-xl md:text-3xl">{hero?.tagline || "Web Developer"}</h3>
    <p class="prose-lg prose-neutral mt-5">
      {hero?.bio?.split('\n\n')[0] || "Apasionado por crear experiencias web únicas y funcionales, combinando diseño y tecnología para ofrecer soluciones innovadoras."}
    </p>
  </div>
  <ul class="flex gap-2 flex-wrap">
    <li class="fade-in">
      <SocialButton to={CONTACT.Linkedin} newPage={true}>
        <LinkedinIcon class="size-6" />
        <span class="">LinkedIn</span>
      </SocialButton>
    </li>
    <li class="fade-in">
      <SocialButton to={CONTACT.Github} newPage={true}>
        <GithubIcon class="size-6" />
        GitHub
      </SocialButton>
    </li>
    <li class="fade-in">
      <SocialButton to="mailto:nicolasrodriguez@outlook.com.ar">
        <EmailIcon class="size-6" />
        nicolasrodriguez@outlook.com.ar
      </SocialButton>
    </li>
  </ul>
</Section>

<script>
  import { gsap } from "gsap"
  let tl = gsap.timeline()

  // Register an effect for reuse
  gsap.registerEffect({
    name: "fade",
    effect: (targets, config) => {
      return gsap.from(targets, {
        duration: config.duration,
        opacity: 0, 
        stagger: 0.3,
      });
    },
    defaults: {duration: 2},
    extendTimeline: true
  });

  tl.fade(".fade-in", {duration: 3})
</script>
