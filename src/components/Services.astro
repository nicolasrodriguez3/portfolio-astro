---
import { getServicios } from "../lib/content"

const services = await getServicios()
---

<section id="servicios" class="w-full px-3">
  <div class="stack-section relative mx-auto w-full" style="height: 100dvh; max-width: 672px;">
    <h2
      data-title="Mis servicios"
      class="section-title text-3xl font-bold tracking-tighter sm:text-4xl md:text-5xl pt-44 z-10 relative pointer-events-none"
    >
      Mis servicios
    </h2>

    <div class="absolute" style="top: 30vh; left: 0; right: 0;">
      <div class="relative mx-auto px-3" style="max-width: 36rem;">
        {
          services.map((service, index) => (
            <article class="service-card" data-index={index}>
              <div
                class="card-body rounded-lg border border-sky-900/30 dark:border-sky-100/20 bg-white dark:bg-neutral-900 p-8 shadow-sm"
              >
                <h3 class="text-3xl font-semibold text-balance mb-6 text-violet-800 dark:text-violet-300">
                  {service.name}
                </h3>
                <p class="text-pretty text-gray-600 dark:text-gray-50/90 text-xl leading-relaxed">
                  {service.description}
                </p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .service-card {
    position: absolute;
    left: 0;
    width: 100%;
    will-change: transform;
  }

  .service-card[data-index="0"] {
    top: 16px;
    z-index: 1;
  }
  .service-card[data-index="1"] {
    top: 8px;
    z-index: 2;
  }
  .service-card[data-index="2"] {
    top: 0;
    z-index: 3;
  }

  .card-body {
    backdrop-filter: blur(4px);
  }

  @media (hover: hover) {
    .card-body:hover {
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
    }
  }
</style>

<script>
  import { gsap } from "gsap"
  import { ScrollTrigger } from "gsap/ScrollTrigger"

  gsap.registerPlugin(ScrollTrigger)

  // -- cards + title --
  const titleEl = document.querySelector<HTMLElement>(".section-title")
  const cards = gsap.utils.toArray<HTMLElement>(".service-card")

  // Phase 1: Title + Card 1 entran juntos cuando la sección asoma
  const enterTl = gsap.timeline({
    scrollTrigger: {
      trigger: ".stack-section",
      start: "top 85%",
      end: "top 25%",
      scrub: 1,
    },
  })

  enterTl.from([titleEl, cards[0]], {
    y: 80,
    opacity: 0,
    ease: "power3.out",
  })

  // Phase 2: Pin en top top para que title + card 1 queden fijos,
  //          mientras card 2 y card 3 se apilan encima
  const pinTl = gsap.timeline({
    scrollTrigger: {
      trigger: ".stack-section",
      pin: true,
      start: "top top",
      end: "+=80%",
      scrub: 1.5,
      anticipatePin: 1,
    },
  })

  // Card 2: opacity llega a 100% al ~85%, transform sigue al 100%
  pinTl.from(cards[1], {
    opacity: 0,
    ease: "power2.out",
    duration: 0.85,
  })
  pinTl.from(cards[1], {
    y: window.innerHeight,
    rotation: 2.5,
    ease: "power4.out",
  }, 0)

  // Card 3: idem, empieza antes de que termine card 2
  pinTl.from(cards[2], {
    opacity: 0,
    ease: "power2.out",
    duration: 0.85,
  }, "-=0.2")
  pinTl.from(cards[2], {
    y: window.innerHeight,
    rotation: -2,
    ease: "power4.out",
  }, "-=0.2")
</script>
