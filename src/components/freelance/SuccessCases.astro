---
import { projects } from '@/data/projects'
import Container from '@/components/ui/Container.astro'
import SectionTitle from '@/components/ui/SectionTitle.astro'
import AnimatedSection from '@/components/ui/AnimatedSection'
import ProjectCard from '@/components/shared/ProjectCard.astro'

const successCases = projects.filter(
  (p) => p.casoExito?.problema && p.casoExito?.solucion && p.casoExito?.resultado,
)

const hasCases = successCases.length > 0
---

{hasCases && (
  <section id="casos" class="section-padding">
    <Container>
      <SectionTitle
        title="Casos de Éxito"
        subtitle="Proyectos reales con resultados medibles para mis clientes"
      />

      <AnimatedSection
        animation="slide-up"
        stagger={0.15}
        className="mt-12 grid grid-cols-1 md:grid-cols-2 gap-6"
      >
        {successCases.map((project) => (
          <ProjectCard
            title={project.title}
            description={project.description}
            image={project.image}
            technologies={project.technologies}
            linkToCode={project.linkToCode}
            deployedSite={project.deployedSite}
            casoExito={project.casoExito}
            slug={project.slug}
          />
        ))}
      </AnimatedSection>
    </Container>
  </section>
)}
