---
import type { ExperienceCardProps } from '@/types'
import { formatDateRange } from '@/lib/utils'
import TechBadge from '@/components/ui/TechBadge.astro'

export interface Props extends ExperienceCardProps {}

const { experience, className } = Astro.props

const {
  company,
  role,
  startDate,
  endDate,
  responsibilities,
  achievements,
  technologies,
} = experience

const dateRange = formatDateRange(startDate, endDate)
---

<article
  class="bg-zinc-900 border border-zinc-800 rounded-xl p-6 space-y-4 {className ?? ''}"
>
  <!-- Header -->
  <div class="space-y-1">
    <span class="text-sm text-zinc-500">{dateRange}</span>
    <h3 class="text-xl font-semibold text-zinc-100">{role}</h3>
    <p class="text-zinc-400">{company}</p>
  </div>

  <!-- Responsibilities -->
  {responsibilities && responsibilities.length > 0 && (
    <div>
      <h4 class="text-sm font-medium text-zinc-500 mb-2">Responsabilidades</h4>
      <ul class="space-y-1.5">
        {responsibilities.map((r) => (
          <li class="text-sm text-zinc-400 flex gap-2">
            <span class="text-zinc-600 mt-0.5 select-none">•</span>
            <span>{r}</span>
          </li>
        ))}
      </ul>
    </div>
  )}

  <!-- Achievements -->
  {achievements && achievements.length > 0 && (
    <div>
      <h4 class="text-sm font-medium text-zinc-500 mb-2">Logros</h4>
      <ul class="space-y-1.5">
        {achievements.map((a) => (
          <li class="text-sm text-zinc-400 flex gap-2">
            <span class="text-indigo-400 mt-0.5 select-none">✦</span>
            <span>{a}</span>
          </li>
        ))}
      </ul>
    </div>
  )}

  <!-- Technologies -->
  {technologies && technologies.length > 0 && (
    <div class="flex flex-wrap gap-2 pt-1">
      {technologies.map((tech) => (
        <TechBadge technology={tech.toLowerCase()} size="sm" />
      ))}
    </div>
  )}
</article>
