---
import type { TimelineProps } from '@/types'

export interface Props extends TimelineProps {}

const { items, className } = Astro.props
---

{
  items.length > 0 && (
    <div class="relative {className ?? ''}">
      <!-- Vertical line -->
      <div
        class="absolute left-4 md:left-6 top-0 bottom-0 w-px bg-zinc-800"
        aria-hidden="true"
      ></div>

      <div class="space-y-12">
        {items.map((item) => (
          <div class="relative pl-12 md:pl-16">
            <!-- Dot -->
            <div
              class={`absolute left-2.5 md:left-4.5 top-1.5 w-3 h-3 rounded-full border-2 ${
                item.isCurrent
                  ? 'bg-indigo-500 border-indigo-400 shadow-lg shadow-indigo-500/20'
                  : 'bg-zinc-900 border-zinc-700'
              }`}
              style="left: 13px;"
              aria-hidden="true"
            ></div>

            <!-- Card -->
            <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-6">
              <span class="text-sm text-zinc-500">{item.date}</span>
              <h3 class="text-xl font-semibold text-zinc-100 mt-1">
                {item.title}
              </h3>
              <p class="text-zinc-400">{item.subtitle}</p>

              {item.description && (
                <p class="text-zinc-400 mt-2">{item.description}</p>
              )}

              {item.children && <div class="mt-3">{item.children}</div>}
            </div>
          </div>
        ))}
      </div>
    </div>
  )
}
